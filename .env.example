# ─── إعدادات الخادم ───────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── مفتاح التشفير (غيّر هذا لقيمة عشوائية طويلة في الإنتاج) ────────────
# يمكن توليده بـ: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_IN_PRODUCTION

# ─── بريد الطبيب (يمكن إضافة أكثر من طبيب بفاصلة) ───────────────────────
DOCTOR_EMAILS=doctor@clinic.com,doctor2@clinic.com

# ─── النطاقات المسموح لها بالاتصال بالخادم (CORS) ────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://your-frontend-domain.com
